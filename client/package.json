{
  "name": "verilog-studio-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "tauri": "tauri",
    "app:dev": "tauri dev",
    "app:build": "tauri build",
    "bundle:tools:mac": "bash src-tauri/scripts/bundle-macos-tools.sh",
    "bundle:tools:win": "powershell -ExecutionPolicy Bypass -File src-tauri/scripts/bundle-windows-tools.ps1",
    "bundle:tools:linux": "bash src-tauri/scripts/bundle-linux-tools.sh",
    "app:build:mac": "npm run bundle:tools:mac && tauri build",
    "app:build:win": "npm run bundle:tools:win && tauri build",
    "app:build:linux": "npm run bundle:tools:linux && tauri build"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@tauri-apps/api": "^2.11.1",
    "@yowasp/yosys": "^0.65.176-dev.1145",
    "netlistsvg": "^1.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "prettier": "^3.9.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.2",
    "vitest": "^2.1.9"
  }
}
