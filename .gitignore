# Dependencies
node_modules/

# Build output
dist/
.vite/
*.tsbuildinfo

# Local env / editor
.env
.env.local
.DS_Store
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Emscripten SDK / WASM build scratch.
# The runtime artifacts the site actually serves live in client/public/wasm and
# ARE committed; only local toolchain build dirs should be ignored.
emsdk/
*.o

# Simulation scratch
*.vvp
dump.vcd
# Machine-specific Icarus config the tools dump at runtime
myconf.txt
**/myconf.txt

# Packaged desktop builds / installers (produced by `tauri build` and CI)
desktop-build/
*.dmg
*.AppImage
*.msi
*.deb
*.rpm

# Mobile icon variants generated by `tauri icon` (we only build desktop)
client/src-tauri/icons/android/
client/src-tauri/icons/ios/
client/src-tauri/icons/64x64.png
